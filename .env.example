# multiCAD CLI Agent — Environment Variables
# Copy this file to .env and fill in your values.
#
# Usage:  copy .env.example .env   (then edit .env)

# ── AI Provider (choose one) ──────────────────────────────────────────────────

# Anthropic / Claude (preferred)
# ANTHROPIC_API_KEY=sk-ant-...

# MiniMax international (fallback, OpenAI-compatible)
# Get your key at: https://platform.minimax.io
# MINIMAX_API_KEY=sk-api-...

# ── MCP Server ────────────────────────────────────────────────────────────────

# URL of the running MCP server (auto-detected from src/config.json if not set)
# MCP_URL=http://localhost:8889/mcp

# ── Optional tuning ───────────────────────────────────────────────────────────

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# MiniMax model to use (default: MiniMax-M2)
# MINIMAX_MODEL=MiniMax-M2

# Maximum AI→tool-call turns per user message before stopping (default: 20)
# AGENT_MAX_TURNS=20
